{
    "name": "mi-lopez/jira-cli-wizard",
    "description": "A beautiful CLI wizard for creating Jira tickets with interactive prompts and smart defaults",
    "type": "library",
    "keywords": ["jira", "cli", "wizard", "ticket", "issue", "agile"],
    "homepage": "https://github.com/mi-lopez/jira-cli-wizard",
    "license": "MIT",
    "authors": [
        {
            "name": "mi-lopez",
            "email": "miguel.lopezt86@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "symfony/console": "^6.0|^7.0",
        "guzzlehttp/guzzle": "^7.0",
        "symfony/process": "^6.0|^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/phpstan": "^1.0",
        "symfony/var-dumper": "^6.0|^7.0"
    },
    "autoload": {
        "psr-4": {
            "MiLopez\\JiraCliWizard\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MiLopez\\JiraCliWizard\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/jira-wizard"
    ],
    "scripts": {
        "test": "phpunit",
        "cs-check": "php-cs-fixer fix --config=.php-cs-fixer.php --dry-run --diff --verbose",
        "cs-fix": "php-cs-fixer fix --config=.php-cs-fixer.php --verbose",
        "phpstan": "phpstan analyse --configuration=phpstan.neon",
        "post-install-cmd": [
            "@php src/Installer.php"
        ],
        "post-update-cmd": [
            "@php src/Installer.php"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}